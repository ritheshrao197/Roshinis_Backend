              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "Wishlist",
      "item": [
        {
          "name": "Get Wishlist",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/wishlist?userId=USER_ID"
          }
        },
        {
          "name": "Add To Wishlist",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/wishlist/add",
            "body": {
              "mode": "raw",
